# ============================================================
# Pratyaksa — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=pratyaksa
POSTGRES_PASSWORD=pratyaksa_secret
POSTGRES_DB=pratyaksa_db
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_USER=pratyaksa
MONGO_PASSWORD=pratyaksa_secret
MONGO_DB=pratyaksa
MONGO_PORT=27017

# --- Backend (Rust) ---
BACKEND_PORT=8080
JWT_SECRET=super_secret_pratyaksa_key_change_in_production
JWT_EXPIRY_HOURS=24
RUST_LOG=info

# --- Frontend (Nuxt) ---
FRONTEND_PORT=3000
# URL API dari sudut pandang browser (lewat Nginx)
# Production: /api/v1  (path relatif, Nginx forward ke backend)
# Development: http://localhost:8080/api/v1
NUXT_PUBLIC_API_BASE=/api/v1
# Target gRPC service bot Telegram untuk mode "Live + Kirim Telegram" di Analisa Kerusakan
# Di Docker: telegram-bot:50051 | Lokal: 127.0.0.1:50051
NUXT_TELEGRAM_GRPC_TARGET=telegram-bot:50051

# --- Telegram Bot (Rust gRPC service) ---
TELEGRAM_BOT_TOKEN=
# Subscriber default (opsional). Bot juga otomatis mendaftar tiap chat yang /start
TELEGRAM_CHAT_ID=
# Backend yang dipakai bot untuk command /status (default sudah ke service "backend")
BOT_BACKEND_URL=http://backend:8080
# Base URL frontend untuk link "Buat Work Order" di pesan Telegram.
# Mengarah ke route /wo/create/{asset_id} → halaman /panel/work_order (lewat Nginx).
# PENTING: Telegram TIDAK menjadikan "localhost" sebagai link (tampil teks biasa).
# Gunakan host ber-titik (IP LAN/domain) agar jadi link & bisa dibuka dari HP:
#   http://10.40.2.117      (akses LAN lewat Nginx port 80)
#   https://domain-kamu.com (produksi)
WO_LINK_BASE=http://10.40.2.117

# --- Nginx (pintu utama aplikasi) ---
APP_PORT=80

# --- Optional Tools ---
MONGO_EXPRESS_PORT=8081
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@pratyaksa.id
PGADMIN_PASSWORD=admin123
