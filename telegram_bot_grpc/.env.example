# Telegram bot gRPC service
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

TELEGRAM_BOT_TOKEN=
# Subscriber default (opsional) — di-seed agar device ini selalu dapat alert
TELEGRAM_CHAT_ID=

# Backend untuk command /status (ringkasan fleet real-time)
# Lokal: http://localhost:8080 | Docker: http://backend:8080
BACKEND_URL=http://backend:8080

# File JSON persistensi daftar subscriber (chat_id yang sudah /start)
SUBSCRIBERS_FILE=./data/subscribers.json

RUST_LOG=info
