# ============================================================
# Pratyaksa Telegram Bot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- gRPC Server ---
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Backend & Frontend ---
BACKEND_URL=http://backend:8080
WO_LINK_BASE=http://localhost
SUBSCRIBERS_FILE=/app/data/subscribers.json

# --- ML & Custom Endpoint ---
ML_TARGET_URL=http://192.168.1.90:6000
CUSTOM_TARGET_URL=http://192.168.1.90:7000

# --- Logging ---
RUST_LOG=info